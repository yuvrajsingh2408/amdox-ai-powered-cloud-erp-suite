  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@index([tenantId])
  @@index([fiscalYearId])
  @@index([deletedAt])
}

model Currency {
  id        String    @id @default(uuid())
  code      String    // e.g. "USD", "EUR", "INR"
  name      String
  symbol    String
  isBase    Boolean   @default(false)
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([code, tenantId])
  @@index([tenantId])
}

model ExchangeRate {
  id           String   @id @default(uuid())
  fromCurrency String
  toCurrency   String
  rate         Float
  date         DateTime @default(now())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model TaxRate {
  id          String    @id @default(uuid())
  name        String    // e.g. "GST 18%", "VAT 15%"
  percentage  Float
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
}

model BankAccount {
  id            String            @id @default(uuid())
  accountName   String
  accountNumber String
  routingNumber String?
  bankName      String
  balance       Float             @default(0.0)
  currency      String            @default("USD")
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  transactions  BankTransaction[]

  @@index([tenantId])
  @@index([deletedAt])
}

model BankTransaction {
  id            String      @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  date          DateTime
  description   String
  amount        Float       // Positive for deposits, negative for withdrawals
  reference     String?
  isReconciled  Boolean     @default(false)
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId])
  @@index([bankAccountId])
}

// --- NEW SUPPLY CHAIN & REQUISITIONS MODELS ---

model PurchaseRequisition {
  id           String                    @id @default(uuid())
  prNumber     String                    @unique
  requesterId  String
  requester    Employee                  @relation(fields: [requesterId], references: [id])
  departmentId String
  department   Department                @relation(fields: [departmentId], references: [id])
  status       String                    @default("PENDING_DEPT") // PENDING_DEPT, PENDING_FINANCE, APPROVED, REJECTED
  totalAmount  Float
  reason       String
  vendorId     String?
  vendor       Vendor?                   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  tenantId     String
  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  deletedAt    DateTime?
  items        PurchaseRequisitionItem[]

  @@index([tenantId])
  @@index([requesterId])
  @@index([departmentId])
  @@index([deletedAt])
}

model PurchaseRequisitionItem {
  id            String              @id @default(uuid())
  requisitionId String
  requisition   PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product             @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Float
  total         Float
  tenantId      String

  @@index([requisitionId])
  @@index([productId])
}

// --- AI FORECASTING & BI MODELS ---

model ForecastRun {
  id             String               @id @default(uuid())
  productId      String
  product        Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  runDate        DateTime             @default(now())
  forecastPeriod Int                  // Number of days forecasted (e.g. 7, 30)
  accuracyMape   Float                @default(0.0) // Mean Absolute Percentage Error
  algorithm      String               // PROPHET, LSTM, LINEAR_REGRESSION, etc.
  tenantId       String
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  predictions    ForecastPrediction[]

  @@index([tenantId])
  @@index([productId])
  @@index([deletedAt])
}

model ForecastPrediction {
  id              String      @id @default(uuid())
  runId           String
  run             ForecastRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  date            DateTime
  quantity        Float
  confidenceLower Float
  confidenceUpper Float
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([runId])
}

model BIDashboard {
  id         String    @id @default(uuid())
  name       String
  layoutJson String    // Layout data for drag-and-drop builder widgets
  isCustom   Boolean   @default(true)
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([tenantId])
  @@index([deletedAt])
}

// --- NEW PROJECT MANAGEMENT & CRM MODELS ---

model Client {
  id        String    @id @default(uuid())
  name      String
  company   String
  email     String    @unique
  phone     String?
  address   String?
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  projects  Project[]
  meetings  Meeting[]
  deals     Deal[]

  @@index([tenantId])
  @@index([deletedAt])
}

model Lead {
  id            String         @id @default(uuid())
  name          String
  company       String
  email         String         @unique
  phone         String?
  source        String         @default("WEBSITE") // WEBSITE, REFERRAL, LINKEDIN, CAMPAIGN
  status        String         @default("NEW") // NEW, CONTACTED, QUALIFIED, PROPOSAL, WON, LOST
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  opportunities Opportunity[]
  meetings      Meeting[]

  @@index([tenantId])
  @@index([deletedAt])
}

model Opportunity {
  id        String    @id @default(uuid())
  name      String
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stage     String    @default("QUALIFICATION") // QUALIFICATION, PROPOSAL, NEGOTIATION, CLOSED_WON, CLOSED_LOST
  value     Float
  closeDate DateTime
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([leadId])
  @@index([deletedAt])
}

model Deal {
  id        String    @id @default(uuid())
  name      String
  amount    Float
  stage     String    @default("NEW") // NEW, DISCOVERY, PROPOSAL, CLOSED_WON, CLOSED_LOST
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([clientId])
  @@index([deletedAt])
}

model Meeting {
  id              String    @id @default(uuid())
  title           String
  description     String?
  date            DateTime
  durationMinutes Int       @default(30)
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([deletedAt])
}

model Reminder {
  id          String    @id @default(uuid())
  title       String
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([userId])
  @@index([deletedAt])
}

model Sprint {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  endDate   DateTime
  status    String    @default("PLANNING") // PLANNING, ACTIVE, COMPLETED
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tasks     Task[]

  @@index([tenantId])
  @@index([projectId])
  @@index([deletedAt])
}

model TaskComment {
  id        String    @id @default(uuid())
  taskId    String
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   String
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([taskId])
  @@index([userId])
  @@index([tenantId])
}

model TaskAttachment {
  id             String    @id @default(uuid())
  taskId         String
  task           Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName       String
  fileUrl        String
  uploadedById   String
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([taskId])
}

model TaskActivity {
  id             String    @id @default(uuid())
  taskId         String
  task           Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action         String
  performedById  String
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([taskId])
}

// --- DMS & Notification Models ---

model Document {
  id           String               @id @default(uuid())
  title        String
  description  String?
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  version      String               @default("1.0.0")
  status       String               @default("ACTIVE") // ACTIVE, ARCHIVED, TRASHED
  tags         String?              @default("")
  isFavorite   Boolean              @default(false)
  folderId     String?
  folder       DocumentFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tenantId     String
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy    String
  updatedBy    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?
  versions     DocumentVersion[]
  shares       DocumentShare[]
  permissions  DocumentPermission[]
  comments     DocumentComment[]

  @@index([tenantId])
  @@index([folderId])
  @@index([deletedAt])
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    String
  fileUrl    String
  fileName   String
  fileSize   Int
  mimeType   String
  tenantId   String
  createdBy  String
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([documentId])
}

model DocumentFolder {
  id        String           @id @default(uuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  DocumentFolder[] @relation("FolderHierarchy")
  documents Document[]
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([parentId])
  @@index([deletedAt])
}

model DocumentPermission {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  role       String?  // Target RoleName
  userId     String?  // Target User ID
  accessType String   // READ, WRITE, ADMIN
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([documentId])
}

model DocumentShare {
  id         String    @id @default(uuid())
  documentId String
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sharedWith String?   // User ID or Email
  accessType String    @default("READ") // READ, WRITE
  token      String?   @unique // Public share link token
  expiresAt  DateTime? // Share Expiry Date
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  String
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([documentId])
}

model DocumentComment {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  comment    String
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([documentId])
}

// NotificationPreference
model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String
  emailEnabled  Boolean  @default(true)
  smsEnabled    Boolean  @default(false)
  pushEnabled   Boolean  @default(true)
  inAppEnabled  Boolean  @default(true)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// NotificationTemplate
model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String   // Unique template code, e.g. LEAVE_REQUESTED
  subject   String
  content   String   // Template text with placeholders like {{employeeName}}
  channel   String   // EMAIL, SMS, PUSH, IN_APP
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, tenantId])
  @@index([tenantId])
}

// EmailQueue
model EmailQueue {
  id        String   @id @default(uuid())
  to        String
  subject   String
  body      String
  status    String   @default("PENDING") // PENDING, SENT, FAILED
  attempts  Int      @default(0)
  error     String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// SMSQueue
model SMSQueue {
  id        String   @id @default(uuid())
  to        String
  message   String
  status    String   @default("PENDING") // PENDING, SENT, FAILED
  attempts  Int      @default(0)
  error     String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// PushNotification
model PushNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  status    String   @default("PENDING") // PENDING, SENT, FAILED
  error     String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
