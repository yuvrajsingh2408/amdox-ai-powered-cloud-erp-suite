datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Tenant Model (Multi-Tenancy)
model Tenant {
  id          String    @id @default(uuid())
  name        String
  subdomain   String    @unique
  status      String    @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Profile Settings
  logoUrl     String?
  address     String?
  phone       String?
  email       String?
  currency    String?   @default("USD")
  taxId       String?

  users                User[]
  roles                Role[]
  employees            Employee[]
  departments          Department[]
  leaves               Leave[]
  attendances          Attendance[]
  salaryStructures     SalaryStructure[]
  payrollRuns          PayrollRun[]
  payslips             Payslip[]
  accounts             Account[]
  transactions         Transaction[]
  transactionLines     TransactionLine[]
  invoices             Invoice[]
  payments             Payment[]
  vendors              Vendor[]
  purchaseOrders       PurchaseOrder[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceipts        GoodsReceipt[]
  products             Product[]
  warehouses           Warehouse[]
  stockMovements       StockMovement[]
  projects             Project[]
  tasks                Task[]
  milestones           Milestone[]
  resourceAllocations  ResourceAllocation[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  systemSettings       SystemSetting[]
  documents            Document[]
  documentFolders      DocumentFolder[]
  documentShares       DocumentShare[]
  documentPermissions  DocumentPermission[]
  documentComments     DocumentComment[]
  notificationPreferences NotificationPreference[]
  notificationTemplates NotificationTemplate[]
  emailQueues          EmailQueue[]
  smsQueues            SMSQueue[]
  pushNotifications    PushNotification[]
  announcements        Announcement[]
  aiConversations      AIConversation[]
  aiPromptTemplates    AIPromptTemplate[]
  aiInsights           AIInsight[]
  aiRecommendations    AIRecommendation[]
  aiQueryHistories     AIQueryHistory[]
  reports              Report[]
  reportTemplates      ReportTemplate[]
  scheduledReports     ScheduledReport[]
  dashboardWidgets     DashboardWidget[]
  widgetLayouts        WidgetLayout[]
  exportHistories      ExportHistory[]
  analyticsSnapshots   AnalyticsSnapshot[]
  workflows            Workflow[]
  workflowInstances    WorkflowInstance[]
  workflowApprovals    WorkflowApproval[]
  escalationRules      EscalationRule[]
  workflowTemplates    WorkflowTemplate[]
  customerPortalUsers  CustomerPortalUser[]
  vendorPortalUsers    VendorPortalUser[]
  supportTickets       SupportTicket[]
  knowledgeBaseArticles KnowledgeBaseArticle[]
  portalAnnouncements  PortalAnnouncement[]
  customerOrders       CustomerOrder[]
  customerPayments     CustomerPayment[]
  vendorQuotations     VendorQuotation[]
  vendorInvoices       VendorInvoice[]
  vendorShipments      VendorShipment[]
  portalNotifications  PortalNotification[]
  portalActivities     PortalActivity[]
  portalDownloads      PortalDownload[]
  portalFavorites      PortalFavorite[]
  userSessions         UserSession[]
  loginHistories       LoginHistory[]
  devices              Device[]
  trustedDevices       TrustedDevice[]
  apiKeys              ApiKey[]
  apiTokens            ApiToken[]
  securityPolicies     SecurityPolicy[]
  passwordPolicies     PasswordPolicy[]
  ipWhitelists         IPWhitelist[]
  blockedIps           BlockedIP[]
  auditEvents          AuditEvent[]
  securityAlerts       SecurityAlert[]
  dataRetentionPolicies DataRetentionPolicy[]
  backupJobs           BackupJob[]
  backupHistories      BackupHistory[]
  recoveryPoints       RecoveryPoint[]
  complianceRules      ComplianceRule[]
  complianceReports    ComplianceReport[]
  mfaRecoveryCodes     MFARecoveryCode[]

  tenantConfigurations TenantConfiguration[]
  tenantUsages         TenantUsage[]
  licenses             License[]
  licenseUsages        LicenseUsage[]
  featureAccesses      FeatureAccess[]
  integrations         Integration[]
  webhooks             Webhook[]
  smtpConfigurations   SMTPConfiguration[]
  storageProviders     StorageProvider[]
  fileStorages         FileStorage[]
  systemJobs           SystemJob[]
  cronJobs             CronJob[]
  queueJobs            QueueJob[]
  queueHistories       QueueHistory[]
  workerNodes          WorkerNode[]
  cacheStatistics      CacheStatistic[]
  systemMetrics        SystemMetric[]
  healthChecks         HealthCheck[]
  deploymentHistories  DeploymentHistory[]
  pluginInstallations  PluginInstallation[]
  customBrandings      CustomBranding[]
  themeConfigurations  ThemeConfiguration[]
  maintenanceWindows   MaintenanceWindow[]
  errorLogs            ErrorLog[]
  serverLogs           ServerLog[]
  systemAlerts         SystemAlert[]
  serviceStatuses      ServiceStatus[]
  databaseStatistics   DatabaseStatistic[]
  databaseBackups      DatabaseBackup[]
  migrationHistories   MigrationHistory[]
  environmentVariables EnvironmentVariable[]

  // Finance extensions
  customers            Customer[]
  fiscalYears          FiscalYear[]
  financialPeriods     FinancialPeriod[]
  currencies           Currency[]
  exchangeRates        ExchangeRate[]
  taxRates             TaxRate[]
  bankAccounts         BankAccount[]
  bankTransactions     BankTransaction[]

  // Supply Chain extensions
  purchaseRequisitions PurchaseRequisition[]
  storageLocations     StorageLocation[]

  // AI & BI extensions
  forecastRuns         ForecastRun[]
  forecastPredictions  ForecastPrediction[]
  biDashboards         BIDashboard[]

  // Project Management & CRM extensions
  clients              Client[]
  leads                Lead[]
  opportunities        Opportunity[]
  deals                Deal[]
  meetings             Meeting[]
  reminders            Reminder[]
  sprints              Sprint[]
  taskComments         TaskComment[]
  taskAttachments      TaskAttachment[]
  taskActivities       TaskActivity[]

  @@index([deletedAt])
  @@index([subdomain])
}

// User Model
model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  firstName    String
  lastName     String
  status       String        @default("ACTIVE") // ACTIVE, INACTIVE, INVITED, LOCKED
  tenantId     String?
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  // Security/Verification fields
  failedLoginAttempts      Int       @default(0)
  lockedUntil              DateTime?
  twoFactorEnabled         Boolean   @default(false)
  twoFactorSecret          String?
  avatarUrl                String?
  verificationToken        String?
  verificationTokenExpires DateTime?
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?

  employee      Employee?
  auditLogs     AuditLog[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  userRoles     UserRole[]
  reminders     Reminder[]
  taskComments  TaskComment[]
  aiConversations      AIConversation[]
  aiPromptTemplates    AIPromptTemplate[]
  aiQueryHistories     AIQueryHistory[]
  aiInsights           AIInsight[]
  workflowApprovals    WorkflowApproval[]
  approvalHistories    ApprovalHistory[]
  userSessions         UserSession[]
  loginHistories       LoginHistory[]
  devices              Device[]
  trustedDevices       TrustedDevice[]
  apiKeys              ApiKey[]
  apiTokens            ApiToken[]
  mfaRecoveryCodes     MFARecoveryCode[]
  auditEvents          AuditEvent[]
  userDirectPermissions UserDirectPermission[]

  @@index([tenantId])
  @@index([deletedAt])
  @@index([email])
}

// Role Model
model Role {
  id          String           @id @default(uuid())
  name        String           // ADMIN, HR_MANAGER, FINANCE_MANAGER, SCM_MANAGER, PROJECT_MANAGER, EMPLOYEE, VIEWER
  description String?
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@index([deletedAt])
}

// Permission Model
model Permission {
  id          String           @id @default(uuid())
  name        String           @unique // e.g. "READ_USERS", "WRITE_USERS", "PROCESS_PAYROLL"
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  roles       RolePermission[]

  @@index([deletedAt])
}

// RolePermission Model (Join Table)
model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@index([deletedAt])
}

// UserRole Model (Join Table)
model UserRole {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([deletedAt])
}

// RefreshToken Model
model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Session details
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([deletedAt])
}

// Employee Model (HR)
model Employee {
  id             String               @id @default(uuid())
  userId         String?              @unique
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeCode   String               @unique
  firstName      String
  lastName       String
  email          String               @unique
  phone          String?
  departmentId   String
  department     Department           @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  managedDept    Department?          @relation("DepartmentManager")
  designation    String
  dateOfJoining  DateTime
  status         String               @default("ACTIVE")
  salary         Float
  tenantId       String
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?

  // Avatar and management details
  avatarUrl      String?
  managerId      String?
  manager        Employee?            @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates   Employee[]           @relation("EmployeeManager")

  leaves               Leave[]
  attendances          Attendance[]
  salaryStructure      SalaryStructure?
  payslips             Payslip[]
  tasks                Task[]
  allocations          ResourceAllocation[]
  purchaseRequisitions PurchaseRequisition[]

  @@index([tenantId])
  @@index([departmentId])
  @@index([deletedAt])
}

// Department Model
model Department {
  id                  String                @id @default(uuid())
  name                String                @unique
  managerId           String?               @unique
  manager             Employee?             @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees           Employee[]            @relation("DepartmentEmployees")
  tenantId            String
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
  purchaseRequisitions PurchaseRequisition[]

  @@index([tenantId])
  @@index([deletedAt])
}

// Leave Model
model Leave {
  id           String    @id @default(uuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    String    // SICK, CASUAL, ANNUAL, MATERNITY, PATERNITY, UNPAID
  startDate    DateTime
  endDate      DateTime
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reason       String
  approvedById String?
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([tenantId])
  @@index([employeeId])
  @@index([deletedAt])
}

// Attendance Model
model Attendance {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  clockIn    DateTime
  clockOut   DateTime?
  status     String    @default("PRESENT") // PRESENT, ABSENT, LATE, HALF_DAY
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  // Break/Timing Trackers
  breakStart   DateTime?
  breakEnd     DateTime?
  workingHours Float?
  overtime     Float?
  lateArrival  Boolean   @default(false)
  earlyExit    Boolean   @default(false)

  @@unique([employeeId, date])
  @@index([tenantId])
  @@index([employeeId])
  @@index([deletedAt])
}

// Salary Structure Model
model SalaryStructure {
  id          String    @id @default(uuid())
  employeeId  String    @unique
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  basicSalary Float
  allowances  Float     @default(0.0)
  deductions  Float     @default(0.0)
  netSalary   Float
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Detailed breakdown components
  grossSalary     Float     @default(0.0)
  bonus           Float     @default(0.0)
  incentives      Float     @default(0.0)
  tax             Float     @default(0.0)
  pf              Float     @default(0.0)
  professionalTax Float     @default(0.0)

  @@index([tenantId])
  @@index([deletedAt])
}

// Payroll Run Model
model PayrollRun {
  id          String    @id @default(uuid())
  month       Int
  year        Int
  status      String    @default("DRAFT") // DRAFT, PROCESSED, PAID
  processedAt DateTime?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  payslips    Payslip[]

  @@index([tenantId])
  @@index([deletedAt])
}

// Payslip Model
model Payslip {
  id           String     @id @default(uuid())
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  basicSalary  Float
  allowances   Float
  deductions   Float
  netSalary    Float
  status       String     @default("UNPAID") // PAID, UNPAID
  paymentDate  DateTime?
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  // Detailed breakdown components
  grossSalary     Float     @default(0.0)
  bonus           Float     @default(0.0)
  incentives      Float     @default(0.0)
  tax             Float     @default(0.0)
  pf              Float     @default(0.0)
  professionalTax Float     @default(0.0)

  @@index([tenantId])
  @@index([employeeId])
  @@index([payrollRunId])
  @@index([deletedAt])
}

// Account (Chart of Accounts)
model Account {
  id               String            @id @default(uuid())
  code             String            @unique
  name             String
  type             String            // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  balance          Float             @default(0.0)
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  transactionLines TransactionLine[]

  @@index([tenantId])
  @@index([deletedAt])
}

// Journal Entry Transaction
model Transaction {
  id          String            @id @default(uuid())
  reference   String            @unique
  description String
  date        DateTime
  status      String            @default("DRAFT") // DRAFT, POSTED
  createdById String
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  lines       TransactionLine[]

  @@index([tenantId])
  @@index([deletedAt])
}

// Transaction line (Double-Entry Debit/Credit)
model TransactionLine {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account     @relation(fields: [accountId], references: [id])
  debit         Float       @default(0.0)
  credit        Float       @default(0.0)
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  @@index([tenantId])
  @@index([transactionId])
  @@index([accountId])
  @@index([deletedAt])
}

// Invoice Model (AP & AR)
model Invoice {
  id            String    @id @default(uuid())
  invoiceNumber String    @unique
  type          String    // AP, AR
  vendorId      String?
  vendor        Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  amount        Float
  tax           Float     @default(0.0)
  status        String    @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE
  dueDate       DateTime
  issuedDate    DateTime
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  payments      Payment[]

  @@index([tenantId])
  @@index([vendorId])
  @@index([customerId])
  @@index([deletedAt])
}

// Payment Model
model Payment {
  id            String    @id @default(uuid())
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount        Float
  paymentDate   DateTime
  paymentMethod String    // CASH, BANK_TRANSFER, CREDIT_CARD, CHECK
  reference     String?
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([tenantId])
  @@index([invoiceId])
  @@index([deletedAt])
}

// Vendor Model (Supply Chain)
model Vendor {
  id                   String                @id @default(uuid())
  name                 String
  code                 String                @unique
  contactName          String?
  email                String                @unique
  phone                String?
  address              String?
  tenantId             String
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  purchaseOrders       PurchaseOrder[]
  invoices             Invoice[]
  purchaseRequisitions PurchaseRequisition[]

  // extended vendor fields
  category             String?               @default("GENERAL")
  rating               Float?                @default(4.0)

  portalUsers          VendorPortalUser[]
  quotations           VendorQuotation[]
  vendorInvoices       VendorInvoice[]
  shipments            VendorShipment[]

  @@index([tenantId])
  @@index([deletedAt])
}

// Purchase Order
model PurchaseOrder {
  id           String              @id @default(uuid())
  poNumber     String              @unique
  vendorId     String
  vendor       Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status       String              @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, RECEIVED, CANCELLED
  totalAmount  Float
  orderDate    DateTime
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
  items        PurchaseOrderItem[]
  goodsReceipt GoodsReceipt[]

  @@index([tenantId])
  @@index([vendorId])
  @@index([deletedAt])
}

// Purchase Order Item
model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Float
  total           Float
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([productId])
  @@index([deletedAt])
}

// Goods Receipt
model GoodsReceipt {
  id              String        @id @default(uuid())
  grNumber        String        @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedDate    DateTime
  receivedById    String
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  // Extended fields
  partialReceive  Boolean       @default(false)
  damagedItems    Int           @default(0)

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([deletedAt])
}

// Product Model (Inventory)
model Product {
  id                   String                  @id @default(uuid())
  name                 String
  sku                  String                  @unique
  description          String?
  unitPrice            Float
  quantityInStock      Int                     @default(0)
  reorderLevel         Int                     @default(10)
  reorderQuantity      Int                     @default(50)
  warehouseId          String?
  warehouse            Warehouse?              @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  tenantId             String
  tenant               Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  deletedAt            DateTime?
  poItems              PurchaseOrderItem[]
  stockMovements       StockMovement[]
  requisitionItems     PurchaseRequisitionItem[]

  // Extended Product attributes
  category             String?                 @default("UNGROUPED")
  brand                String?
  unit                 String?                 @default("PCS")
  hsnCode              String?
  gstRate              Float?                  @default(18.0)

  // AI extensions
  forecastRuns         ForecastRun[]

  // Project task allocations relation
  projectTasks         Task[]

  @@index([tenantId])
  @@index([warehouseId])
  @@index([deletedAt])
}

// Warehouse Model
model Warehouse {
  id                   String               @id @default(uuid())
  name                 String               @unique
  location             String?
  tenantId             String
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  products             Product[]
  storageLocations     StorageLocation[]

  // Extended warehouse attributes
  code                 String               @unique @default("WH-01")

  @@index([tenantId])
  @@index([deletedAt])
}

// Storage Locations mapping (Shelf / Bin)
model StorageLocation {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  name        String    // e.g. Shelf A-1, Bin 5
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([warehouseId])
  @@index([deletedAt])
}

// Stock Movement Tracker
model StockMovement {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        String    // IN, OUT, ADJUSTMENT, TRANSFER, RETURN, DAMAGE
  quantity    Int
  referenceId String?
  date        DateTime  @default(now())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([productId])
  @@index([deletedAt])
}

// Project Model
model Project {
  id          String               @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  status      String               @default("PLANNING") // PLANNING, IN_PROGRESS, COMPLETED, SUSPENDED, ON_HOLD
  budget      Float                @default(0.0)
  actualCost  Float                @default(0.0)
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  tasks       Task[]
  milestones  Milestone[]
  allocations ResourceAllocation[]

  // CRM Extensions
  clientId    String?
  client      Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sprints     Sprint[]

  @@index([tenantId])
  @@index([deletedAt])
}

// Task Model (under Project)
model Task {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  assigneeId  String?
  assignee    Employee? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  startDate   DateTime?
  endDate     DateTime?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Extended SCM integration (Option to allocate SCM item to project task)
  allocatedProductId String?
  allocatedProduct   Product?   @relation(fields: [allocatedProductId], references: [id], onDelete: SetNull)

  // Sprint mappings
  sprintId           String?
  sprint             Sprint?    @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  comments           TaskComment[]
  attachments        TaskAttachment[]
  activities         TaskActivity[]

  @@index([tenantId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([deletedAt])
}

// Milestone Model
model Milestone {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  dueDate     DateTime
  status      String    @default("PENDING") // PENDING, ACHIEVED
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([projectId])
  @@index([deletedAt])
}

// Resource Allocation Model
model ResourceAllocation {
  id                   String    @id @default(uuid())
  projectId            String
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  allocationPercentage Float     @default(100.0)
  roleInProject        String?
  startDate            DateTime
  endDate              DateTime?
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@index([tenantId])
  @@index([projectId])
  @@index([employeeId])
  @@index([deletedAt])
}

// Audit Log Model
model AuditLog {
  id        String    @id @default(uuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  module    String
  details   String?
  ipAddress String?
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([userId])
  @@index([deletedAt])
}

// Notification Model
model Notification {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  message        String
  type           String    @default("INFO") // INFO, WARNING, ALERT
  isRead         Boolean   @default(false)
  priority       String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  readStatus     String    @default("UNREAD") // READ, UNREAD
  deliveryStatus String    @default("DELIVERED") // PENDING, DELIVERED, FAILED
  channel        String    @default("IN_APP") // IN_APP, EMAIL, SMS, PUSH
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([userId])
  @@index([deletedAt])
}

// System Settings Model
model SystemSetting {
  id          String    @id @default(uuid())
  key         String    @unique
  value       String
  description String?
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([deletedAt])
}

// --- NEW FINANCE MODELS ---

model Customer {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  email     String    @unique
  phone     String?
  address   String?
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  invoices  Invoice[]
  portalUsers CustomerPortalUser[]
  orders      CustomerOrder[]
  payments    CustomerPayment[]

  @@index([tenantId])
  @@index([deletedAt])
}

model FiscalYear {
  id        String            @id @default(uuid())
  name      String            // e.g. "FY2026"
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean           @default(false)
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?
  periods   FinancialPeriod[]

  @@index([tenantId])
  @@index([deletedAt])
}

model FinancialPeriod {
  id           String     @id @default(uuid())
  fiscalYearId String
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  name         String     // e.g. "Q1", "Jan-2026"
  startDate    DateTime
  endDate      DateTime
  isLocked     Boolean    @default(false)
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
