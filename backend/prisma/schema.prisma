// --- NEW WORKFLOW AUTOMATION & APPROVAL ENGINE MODELS ---

model Workflow {
  id          String             @id @default(uuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  triggerType String             // "LEAVE", "EXPENSE", "PURCHASE_REQUISITION", "PURCHASE_ORDER", "VENDOR", "EMPLOYEE", "INVOICE", "DOCUMENT", "PROJECT"
  isActive    Boolean            @default(true)
  version     Int                @default(1)
  createdBy   String
  updatedBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  steps       WorkflowStep[]
  instances   WorkflowInstance[]

  @@index([tenantId])
  @@index([deletedAt])
}

model WorkflowStep {
  id             String    @id @default(uuid())
  workflowId     String
  workflow       Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder      Int
  name           String
  approverType   String    // "ROLE", "USER", "MANAGER"
  approverValue  String    // e.g. "ADMIN", "FINANCE_MANAGER", or specific userId
  conditionType  String?   // "AMOUNT_GREATER_THAN", "DEPARTMENT_MATCH", "NONE"
  conditionValue String?
  slaHours       Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workflowId])
}

model WorkflowInstance {
  id                String             @id @default(uuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflowId        String
  workflow          Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  entityType        String
  entityId          String
  status            String             @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "CANCELLED", "ESCALATED", "EXPIRED"
  currentStepIndex  Int                @default(0)
  startedBy         String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  approvals         WorkflowApproval[]

  @@index([tenantId])
  @@index([workflowId])
  @@index([deletedAt])
}

model WorkflowApproval {
  id             String            @id @default(uuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instanceId     String
  instance       WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepOrder      Int
  name           String
  approverRole   String?
  approverUserId String?
  approverUser   User?             @relation(fields: [approverUserId], references: [id], onDelete: SetNull)
  status         String            @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "ESCALATED"
  comments       String?
  slaDeadline    DateTime?
  reminderSentAt DateTime?
  approvedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  history        ApprovalHistory[]

  @@index([tenantId])
  @@index([instanceId])
  @@index([approverUserId])
}

model ApprovalHistory {
  id         String           @id @default(uuid())
  approvalId String
  approval   WorkflowApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  action     String           // "APPROVED", "REJECTED", "ESCALATED", "COMMENT_ADDED"
  actorId    String
  actor      User             @relation(fields: [actorId], references: [id], onDelete: Cascade)
  comments   String?
  createdAt  DateTime         @default(now())

  @@index([approvalId])
  @@index([actorId])
}

model EscalationRule {
  id           String   @id @default(uuid())
