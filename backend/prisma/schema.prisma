  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  triggerHours Int
  actionType   String   // "REASSIGN", "NOTIFY_ADMIN"
  actionValue  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

