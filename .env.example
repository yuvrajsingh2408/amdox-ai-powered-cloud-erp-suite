# ─────────────────────────────────────────────────────────────────────────────
# Amdox ERP — Environment Variables Template
# Copy to .env and fill in values before running.
# NEVER commit real .env files to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development                    # development | production | test
PORT=5000
LOG_LEVEL=info                          # error | warn | info | debug

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/amdox_erp?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=amdox_erp
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redispassword@localhost:6379
REDIS_PASSWORD=redispassword
REDIS_PORT=6379

# ── Authentication (MUST change in production — min 64 chars) ────────────────
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_64_chars_long_for_security_reasons_!!!!
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_minimum_64_chars_long_for_security_!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000      # Comma-separated list for production

# ── AI Service ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Swagger / API Docs ────────────────────────────────────────────────────────
ENABLE_SWAGGER=true                     # false in production (unless explicitly needed)

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@amdox.io

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_TYPE=local                      # local | s3 | gcs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=amdox-erp-uploads

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password
GRAFANA_ROOT_URL=https://monitoring.amdox.io

# ── Domain / SSL ─────────────────────────────────────────────────────────────
DOMAIN=amdox.io
FRONTEND_URL=https://app.amdox.io
BACKEND_URL=https://api.amdox.io

# ── Docker Ports (dev only) ───────────────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=3000
AI_PORT=8000
