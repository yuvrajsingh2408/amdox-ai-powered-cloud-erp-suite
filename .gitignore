docker-compose.override.yml

# ─── Kubernetes Secrets (never commit) ───────────────────────────────────────
k8s/secrets-real.yaml
infra/nginx/ssl/*.pem
infra/nginx/ssl/*.key
infra/nginx/certs/

# ─── IDEs ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Prisma Generated ────────────────────────────────────────────────────────
backend/prisma/generated/
*.db
*.db-journal
*.db.bak
dev.db
dev.db.bak

# ─── Misc ────────────────────────────────────────────────────────────────────
.cache/
tmp/
*.tmp
*.bak
