# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Build Outputs ────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Environment (NEVER commit real secrets) ──────────────────────────────────
.env
.env.local
.env.production
.env.*.local
!.env.example

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
backend/logs/

# ─── Uploads / Media ─────────────────────────────────────────────────────────
backend/uploads/
uploads/

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
playwright-report/
test-results/
.nyc_output/

# ─── Docker ──────────────────────────────────────────────────────────────────
